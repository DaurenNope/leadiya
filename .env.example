# ── Required ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/leadiya
DATABASE_DIRECT_URL=postgresql://postgres:password@localhost:5432/leadiya
REDIS_URL=redis://localhost:6379
NODE_ENV=development

# API (Hono) — defaults are defined in repo-root dev-ports.json (localCliApiPort). Copy matches that file.
PORT=3041
LEADIYA_API_ORIGIN=http://localhost:3041
# Docker Compose forces PORT=3001 inside the api container (see docker-compose.yml environment).

# ── Supabase (auth) ───────────────────────────────────────────
# Dashboard: скопируйте в корневой `.env` и подставьте свой проект (Supabase → Settings → API).
#
# Сервер API
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# JWT Secret (Settings → API) — verify tokens locally; avoids Supabase Auth HTTP on every API call (saves egress).
# SUPABASE_JWT_SECRET=
#
# Та же пара URL + anon key для Vite (обязательно для входа в панель; префикс VITE_ нужен, иначе браузер их не видит)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
#
# Google OAuth (кнопка «Продолжить с Google» в панели): Supabase → Authentication → Providers → Google.
# В Google Cloud Console: OAuth client (Web), Authorized redirect URI = https://<project-ref>.supabase.co/auth/v1/callback
# В Supabase → Authentication → URL Configuration: Redirect URLs — http://localhost:5173/** и продакшен, например:
#   https://app.rahmetlabs.com  и  https://app.rahmetlabs.com/**
# Site URL (production): https://app.rahmetlabs.com — домен Rahmet Labs; DNS A/AAAA или CNAME на ваш хостинг.
#
# Письма (подтверждение и т.д.): Supabase → Authentication → Email Templates — свой текст/HTML и тема.
# Свой домен отправителя: Project Settings → Auth → SMTP Settings (например Resend) + RESEND_* в этом .env.

# Set to "true" to skip JWT auth on all API routes (local dev only)
# AUTH_BYPASS=true  # DANGER: Skips all authentication. Dev only!

# Agent runtimes (e.g. Nous Hermes): HTTP calls to /api/* with header X-Leadiya-Service-Key (min 24 chars). See docs/HERMES_INTEGRATION.md
# Generate + sync hermes/.env: npm run setup:agent-bridge
# LEADIYA_AGENT_SERVICE_KEY=
#
# Optional — npm run verify:agent-api (Hermes-style CRM + outreach smoke):
# LEADIYA_VERIFY_LEAD_ID=00000000-0000-4000-8000-000000000000
# LEADIYA_VERIFY_PHONE_OVERRIDE=+77001234567
# LEADIYA_VERIFY_SEQUENCE_KEY=cold_outreach
# LEADIYA_VERIFY_STEP_INDEX=0
# LEADIYA_VERIFY_SEND=0

# Cache GET /api/scrapers/runs for this many ms (default 8000; 0 = disable). Fewer DB round-trips to Supabase-hosted Postgres.
# SCRAPER_RUNS_CACHE_MS=8000

# Workers: mark scraper_runs stuck in "running" longer than N hours as error (default 6). Frees single-flight for POST /api/scrapers/2gis.
# SCRAPER_RUN_STALE_AFTER_HOURS=6

# Workers: if last_progress_at (list pages / stats / saves) is older than N minutes, mark run error (default 30). Needs migration 0005 + workers running.
# SCRAPER_RUN_NO_PROGRESS_MINUTES=30

# ── Optional integrations ─────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...           # Workers: inbound replies (auto-responder) prefer this over Ollama when set
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OLLAMA_URL=http://localhost:11434
# SMARTPROXY_USER=
# SMARTPROXY_PASS=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# SENTRY_DSN=https://...@sentry.io/...
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=onboarding@resend.dev
# APP_ENCRYPTION_KEY=32-char-minimum-secret-key-here!!

# ── WhatsApp (Baileys) — requires Redis + apps/workers (QR once in worker logs) ────
# Human-in-the-loop: low-confidence classification alerts FOUNDER_WHATSAPP and skips auto-reply unless:
# OUTREACH_AUTO_REPLY_LOW_CONFIDENCE=1
# Or set automation.mode: fully_automatic in config/business.yml (same effect; env false/0 overrides).
# FOUNDER_WHATSAPP=+77001234567
# Max automated WA outbounds per lead in rolling 7d window (then escalate). Default 5. Raise for local simulate:
# OUTREACH_MAX_INBOUND_AUTO_REPLIES=100
#
# WHATSAPP_BAILEYS_ENABLED=true
# Inbound rows in DB + dashboard. Default ON when Baileys is enabled (unset = save replies in лента).
# Set WHATSAPP_INBOUND_LOG=false to skip storing their messages (privacy).
# WHATSAPP_INBOUND_LOG=true
# WHATSAPP_BAILEYS_AUTH_DIR=    # default: apps/workers/data/baileys-auth (gitignored via data/)
# Outbound: defer sends outside window (moveToDelayed, not global worker rate limit)
# WHATSAPP_BUSINESS_HOURS_TZ=Asia/Almaty
# WHATSAPP_BUSINESS_HOURS_START=9
# WHATSAPP_BUSINESS_HOURS_END=19
# Local testing (send anytime): WHATSAPP_BUSINESS_HOURS_START=0 and WHATSAPP_BUSINESS_HOURS_END=24
#
# Two-number E2E (Baileys = A, your phone = B): set a real lead uuid + your mobile, then:
#   npm run verify:wa-test-contact   # writes whatsapp + contact on that lead for inbound matching
#   npm run verify:wa-two-numbers  # preview + optional POST /send
# LEADIYA_VERIFY_LEAD_ID=
# LEADIYA_VERIFY_PHONE_OVERRIDE=+77001234567
# LEADIYA_VERIFY_SEQUENCE_KEY=cold_outreach
# LEADIYA_VERIFY_STEP_INDEX=0
# LEADIYA_VERIFY_SEND=1
#
# Agent key / service sends have no JWT tenant — worker uses DEFAULT_TENANT_ID (uuid in tenants) for Baileys + queue; must match the connected WA session.
# DEFAULT_TENANT_ID=

# ── Lead enrichment (apps/workers dev — needs Redis) ────────────
# Website: runs on any lead with `website` (2GIS link.2gis.com is decoded first).
# BIN-backed: stat.gov.kz (fragile), Goszakup tenders, pk.uchet.kz (needs token):
# UCHET_API_TOKEN=
# 2GIS search enrich: auto for non-2GIS leads; for 2GIS leads use API body { "forceTwogis": true } on POST /api/companies/:id/enrich

# ── Dashboard (production / другой origin) ───────────────────
# Панель: https://app.rahmetlabs.com — задайте DASHBOARD_URL (см. выше).
# Только если UI на другом origin, чем API (без прокси /api на том же домене):
# VITE_PUBLIC_API_ORIGIN=https://api.rahmetlabs.com
# VITE_SUPABASE_* см. блок Supabase выше.

# ── Scraper tuning ────────────────────────────────────────────
# STAGE2_HTTP_ONLY=1          # Skip Playwright fallback for website enrichment
# TWOGIS_CHECKPOINT_DIR=      # Override checkpoint dir (default: .twogis-checkpoints/)
# No TWOGIS_API_KEY — the headless scraper does not use the paid 2GIS Catalog API (browser-only).
# Log every list/search navigation URL in API/worker stdout: TWOGIS_LOG_NAVIGATION=1
