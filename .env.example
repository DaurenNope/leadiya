# ── Required ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/leadiya
DATABASE_DIRECT_URL=postgresql://postgres:password@localhost:5432/leadiya
REDIS_URL=redis://localhost:6379
NODE_ENV=development

# API (Hono) — defaults are defined in repo-root dev-ports.json (localCliApiPort). Copy matches that file.
PORT=3041
LEADIYA_API_ORIGIN=http://localhost:3041
# Docker Compose forces PORT=3001 inside the api container (see docker-compose.yml environment).

# ── Supabase (required for auth; skip with AUTH_BYPASS=true) ──
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# JWT Secret (Settings → API) — verify tokens locally; avoids Supabase Auth HTTP on every API call (saves egress).
# SUPABASE_JWT_SECRET=

# Set to "true" to skip JWT auth on all API routes (local dev only)
# AUTH_BYPASS=true  # DANGER: Skips all authentication. Dev only!

# Agent runtimes (e.g. Nous Hermes): HTTP calls to /api/* with header X-Leadiya-Service-Key (min 24 chars). See docs/HERMES_INTEGRATION.md
# Generate + sync hermes/.env: npm run setup:agent-bridge
# LEADIYA_AGENT_SERVICE_KEY=
#
# Optional — npm run verify:agent-api (Hermes-style CRM + outreach smoke):
# LEADIYA_VERIFY_LEAD_ID=00000000-0000-4000-8000-000000000000
# LEADIYA_VERIFY_PHONE_OVERRIDE=+77001234567
# LEADIYA_VERIFY_SEQUENCE_KEY=cold_outreach
# LEADIYA_VERIFY_STEP_INDEX=0
# LEADIYA_VERIFY_SEND=0

# Cache GET /api/scrapers/runs for this many ms (default 8000; 0 = disable). Fewer DB round-trips to Supabase-hosted Postgres.
# SCRAPER_RUNS_CACHE_MS=8000

# Workers: mark scraper_runs stuck in "running" longer than N hours as error (default 6). Frees single-flight for POST /api/scrapers/2gis.
# SCRAPER_RUN_STALE_AFTER_HOURS=6

# Workers: if last_progress_at (list pages / stats / saves) is older than N minutes, mark run error (default 30). Needs migration 0005 + workers running.
# SCRAPER_RUN_NO_PROGRESS_MINUTES=30

# ── Optional integrations ─────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_URL=http://localhost:11434
# SMARTPROXY_USER=
# SMARTPROXY_PASS=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# SENTRY_DSN=https://...@sentry.io/...
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=onboarding@resend.dev
# APP_ENCRYPTION_KEY=32-char-minimum-secret-key-here!!

# ── WhatsApp (Baileys) — requires Redis + apps/workers (QR once in worker logs) ────
# WHATSAPP_BAILEYS_ENABLED=true
WHATSAPP_INBOUND_LOG=true
# WHATSAPP_BAILEYS_AUTH_DIR=    # default: apps/workers/data/baileys-auth (gitignored via data/)

# ── Lead enrichment (apps/workers dev — needs Redis) ────────────
# Website: runs on any lead with `website` (2GIS link.2gis.com is decoded first).
# BIN-backed: stat.gov.kz (fragile), Goszakup tenders, pk.uchet.kz (needs token):
# UCHET_API_TOKEN=
# 2GIS search enrich: auto for non-2GIS leads; for 2GIS leads use API body { "forceTwogis": true } on POST /api/companies/:id/enrich

# ── Dashboard (production build) ──────────────────────────────
# Only when the UI is hosted on a *different* origin than the API (no /api proxy):
# VITE_PUBLIC_API_ORIGIN=https://api.yourdomain.com

# Dashboard auth (Supabase — same project as backend, exposed to browser via VITE_ prefix)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# ── Scraper tuning ────────────────────────────────────────────
# STAGE2_HTTP_ONLY=1          # Skip Playwright fallback for website enrichment
# TWOGIS_CHECKPOINT_DIR=      # Override checkpoint dir (default: .twogis-checkpoints/)
# No TWOGIS_API_KEY — the headless scraper does not use the paid 2GIS Catalog API (browser-only).
# Log every list/search navigation URL in API/worker stdout: TWOGIS_LOG_NAVIGATION=1
