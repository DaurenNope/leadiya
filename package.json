{
  "name": "leadiya-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@10.8.2",
  "scripts": {
    "postinstall": "patch-package",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@leadiya/api --filter=dashboard",
    "dev:web:stable": "node scripts/dev-web-stable.mjs",
    "dev:dashboard": "npm run dev -w dashboard",
    "dev:api": "npm run dev:api-only -w @leadiya/api",
    "dev:workers": "npm run dev -w @leadiya/workers",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:wa-agent": "vitest run apps/workers/src/lib/wa-agent-log.test.ts apps/workers/src/lib/whatsapp-business-hours.test.ts packages/wa-reply/src/intent-classifier.test.ts apps/workers/src/lib/inbound-auto-reply-limits.test.ts packages/wa-reply/src/auto-responder.test.ts packages/wa-reply/src/inbound-playbook.test.ts apps/workers/src/workers/inbound-reply.integration.test.ts apps/workers/src/workers/inbound-reply.integration.branches.test.ts apps/workers/src/workers/inbound-reply-history.test.ts apps/workers/src/lib/sequence-send-guard.test.ts apps/workers/src/lib/tenant-scope.test.ts apps/workers/src/workers/whatsapp-baileys.worker.test.ts apps/workers/src/lib/serial-by-key.test.ts apps/workers/src/lib/inbound-dedupe.test.ts",
    "test:wa-hardcore": "npm run test:wa-agent && npm test",
    "benchmark:2gis": "npx tsx scripts/benchmark-2gis-scrape.ts",
    "test:stage2-http": "npx tsx scripts/test-stage2-http.ts",
    "smoke:kz-apis": "npx tsx scripts/kz-official-apis-smoke.ts",
    "db:migrate": "npm run db:migrate -w @leadiya/db",
    "db:apply:0004-twogis-card-category": "npx tsx --env-file=.env scripts/apply-migration-0004-twogis-card-category.ts",
    "db:apply:0012-next-outreach-eligible-at": "npx tsx --env-file=.env scripts/apply-migration-0012-next-outreach-eligible-at.ts",
    "db:seed": "npm run db:seed -w @leadiya/db",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "verify:agent-api": "node scripts/verify-agent-api.mjs",
    "verify:agent-outreach": "node scripts/verify-agent-api.mjs",
    "verify:wa-two-numbers": "node scripts/verify-wa-two-numbers.mjs",
    "simulate:wa-convo": "npx tsx --env-file=.env scripts/simulate-wa-convo.ts",
    "bench:wa-reply": "npx tsx --env-file=.env scripts/bench-wa-reply-latency.ts",
    "check:wa-stack": "npx tsx --env-file=.env scripts/check-wa-stack.ts",
    "clean:wa-delayed": "npx tsx --env-file=.env scripts/clean-wa-delayed.ts",
    "inspect:wa-queue": "npx tsx --env-file=.env scripts/inspect-wa-queue.ts",
    "verify:wa-test-contact": "npx tsx --env-file=.env scripts/ensure-wa-test-contact.ts",
    "setup:agent-bridge": "node scripts/setup-agent-bridge.mjs",
    "backfill:twogis-card-category": "npx tsx --env-file=.env scripts/backfill-twogis-card-category.ts",
    "outreach": "npx tsx scripts/run-outreach.ts",
    "outreach:dry": "npx tsx scripts/run-outreach.ts --limit 5",
    "outreach:send": "npx tsx scripts/run-outreach.ts --send --limit 5"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "patch-package": "^8.0.1",
    "turbo": "^2.1.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1"
  }
}
